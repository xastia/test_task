<?xml version="1.0" encoding="utf-8"?>
<!--
  Екран історії вимірювань.
  - Топ: стрілка назад + "Історія"
  - Body: RecyclerView (rcView) зі списком вимірювань
  - Bottom: кнопка "Очистити історію" (з'являється коли є дані)
  - Empty state: текст по центру
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp"
    tools:context=".presentation.HistoryActivity">

    <ImageButton
        android:id="@+id/arrowBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_cream_secondary"
        android:src="@drawable/ic_arrow_left"
        android:scaleType="center"
        android:contentDescription="@android:string/cancel"
        app:tint="@color/text_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:text="@string/history_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        app:fontFamily="@font/rubik_semibold"
        app:layout_constraintStart_toEndOf="@id/arrowBtn"
        app:layout_constraintTop_toTopOf="@id/arrowBtn"
        app:layout_constraintBottom_toBottomOf="@id/arrowBtn" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/arrowBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/delete" />

    <TextView
        android:id="@+id/noResults"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/history_empty"
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:lineSpacingExtra="4dp"
        app:fontFamily="@font/rubik"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/delete"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_button_coral"
        android:stateListAnimator="@null"
        android:text="@string/history_clear"
        android:textColor="@color/text_on_coral"
        android:textSize="14sp"
        android:textAllCaps="false"
        android:visibility="gone"
        app:fontFamily="@font/rubik_semibold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
