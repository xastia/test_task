<?xml version="1.0" encoding="utf-8"?>
<!--
  Картка одного вимірювання в історії.
  Зліва — вертикальний кольоровий маркер (sage/amber/coral у залежності від BPM).
  Центр — BPM великим, дата/час маленьким.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_card_white"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <!-- Кольоровий маркер статусу. Drawable виставляється у ResultAdapter (sage/amber/coral). -->
    <View
        android:id="@+id/statusMarker"
        android:layout_width="5dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_status_marker_sage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/resultText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:text="0 BPM"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:includeFontPadding="false"
        app:fontFamily="@font/rubik_semibold"
        app:layout_constraintStart_toEndOf="@id/statusMarker"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="11:07"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        app:fontFamily="@font/rubik"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="—"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        app:fontFamily="@font/rubik"
        app:layout_constraintTop_toBottomOf="@id/time"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
