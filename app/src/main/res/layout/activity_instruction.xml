<?xml version="1.0" encoding="utf-8"?>
<!--
  Екран інструкції: "Прикладіть палець до камери".
  - Топ: кнопка-закрити
  - Центр: позначка-камера + заголовок + опис
  - Низ: лілова карта з іконкою пальця

  preview — PreviewView, схований у кутку. Потрібен щоб CameraX міг аналізувати
  яскравість і визначити коли користувач закрив об'єктив пальцем.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:paddingStart="24dp"
    android:paddingTop="48dp"
    android:paddingEnd="24dp"
    android:paddingBottom="32dp"
    tools:context=".presentation.InstructionActivity">

    <!-- Топ-бар: кнопка закрити (повернутися на головну) -->
    <ImageButton
        android:id="@+id/imageButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_cream_secondary"
        android:src="@drawable/ic_close"
        android:scaleType="center"
        android:contentDescription="@android:string/cancel"
        app:tint="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Декоративний кружок "об'єктив камери" + текст інструкції -->
    <View
        android:id="@+id/cameraMark"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="56dp"
        android:background="@drawable/bg_camera_circle_dark"
        app:layout_constraintTop_toBottomOf="@id/imageButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/checkingPulse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/instruction_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        app:fontFamily="@font/rubik_semibold"
        app:layout_constraintTop_toBottomOf="@id/cameraMark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/checkingPulse2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:text="@string/instruction_body"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textAlignment="center"
        android:lineSpacingExtra="3dp"
        app:fontFamily="@font/rubik"
        app:layout_constraintTop_toBottomOf="@id/checkingPulse"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Лілова картка з пальцем (ілюстрація) -->
    <FrameLayout
        android:id="@+id/fingerCard"
        android:layout_width="160dp"
        android:layout_height="200dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_card_lilac_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_hand_finger"
            android:contentDescription="@null"
            app:tint="@color/lilac" />
    </FrameLayout>

    <!-- Невидима PreviewView для аналізу яскравості (детекція пальця).
         Розмір 1dp, alpha 0 — для CameraX-аналізатора цього достатньо. -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
