<?xml version="1.0" encoding="utf-8"?>
<!--
  Екран інструкції: "Прикладіть палець до камери".

  Тепер PreviewView ВИДИМИЙ — у круглому CardView 110dp. Користувач бачить
  що камера дійсно працює (без пальця — звичайна картинка, з пальцем — червоне).
  Це дає очевидний зворотний зв'язок.

  Детекція пальця — у InstructionActivity.kt через R-канал (R > 120 + warmup
  + consecutive frames).
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="32dp"
    tools:context=".presentation.InstructionActivity">

    <!-- Топ-бар: кнопка закрити (повернутися на головну) -->
    <ImageButton
        android:id="@+id/imageButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_cream_secondary"
        android:src="@drawable/ic_close"
        android:scaleType="center"
        android:contentDescription="@android:string/cancel"
        app:tint="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- КРУГЛИЙ PREVIEW з камери. CardView з cardCornerRadius=55dp на view 110dp
         = круг. cardElevation=0 щоб не було тіні. -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cameraMark"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="48dp"
        app:cardCornerRadius="55dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/text_primary"
        app:layout_constraintTop_toBottomOf="@id/imageButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/checkingPulse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/instruction_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        app:fontFamily="@font/rubik_semibold"
        app:layout_constraintTop_toBottomOf="@id/cameraMark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/checkingPulse2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:text="@string/instruction_body"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textAlignment="center"
        android:lineSpacingExtra="3dp"
        app:fontFamily="@font/rubik"
        app:layout_constraintTop_toBottomOf="@id/checkingPulse"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Лілова картка з пальцем (ілюстрація) -->
    <FrameLayout
        android:id="@+id/fingerCard"
        android:layout_width="160dp"
        android:layout_height="200dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_card_lilac_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_hand_finger"
            android:contentDescription="@null"
            app:tint="@color/lilac" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
